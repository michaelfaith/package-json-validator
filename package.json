{
  "name": "package-json-validator",
  "version": "1.5.2",
  "description": "Tools to validate package.json files.",
  "keywords": [
    "lint",
    "package.json",
    "package.json linter",
    "package.json validator",
    "validator"
  ],
  "homepage": "https://github.com/michaelfaith/package-json-validator#readme",
  "bugs": {
    "url": "https://github.com/michaelfaith/package-json-validator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelfaith/package-json-validator.git"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "Nick Sullivan",
      "email": "nick@sullivanflock.com"
    },
    {
      "name": "JoshuaKGoldberg",
      "email": "npm@joshuakgoldberg.com",
      "url": "https://joshuakgoldberg.com"
    },
    {
      "name": "michael faith",
      "email": "michaelfaith@users.noreply.github.com",
      "url": "https://michael.faith"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "type": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier .",
    "lint": "eslint . --max-warnings 0",
    "lint:knip": "knip",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "npm-package-arg": "^13.0.2",
    "semver": "^7.7.2",
    "validate-npm-package-license": "^3.0.4",
    "validate-npm-package-name": "^7.0.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@eslint/markdown": "8.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "24.13.0",
    "@types/npm-package-arg": "6.1.4",
    "@types/semver": "7.7.0",
    "@types/validate-npm-package-license": "3.0.3",
    "@types/validate-npm-package-name": "4.0.2",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.22",
    "console-fail-test": "0.6.0",
    "eslint": "10.6.0",
    "eslint-plugin-jsdoc": "63.0.12",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-package-json": "1.5.0",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-yml": "3.6.0",
    "jiti": "2.7.0",
    "knip": "6.24.0",
    "prettier": "3.9.0",
    "prettier-plugin-curly": "0.4.0",
    "prettier-plugin-packagejson": "3.0.0",
    "prettier-plugin-sh": "0.18.0",
    "pretty-quick": "4.2.2",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  }
}
